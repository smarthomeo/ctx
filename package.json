{
  "name": "ctx-for-ai",
  "version": "0.1.0",
  "description": "Terminal context manager for AI coding agents. Generates .ctx.md files that agents read as system context.",
  "main": "dist/index.js",
  "bin": {
    "ctx": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts"
  },
  "keywords": [
    "ai",
    "context",
    "cli",
    "llm",
    "gpt",
    "claude",
    "cursor",
    "token",
    "codebase"
  ],
  "author": "smarthomeo",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "fast-glob": "^3.3.0",
    "ignore": "^5.3.0"
  },
  "repository": {
    "url": "https://github.com/smarthomeo/ctx"
  },
  "homepage": "https://github.com/smarthomeo/ctx#readme",
  "bugs": {
    "url": "https://github.com/smarthomeo/ctx/issues"
  }
}
